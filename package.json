{
  "name": "osmtw",
  "version": "4.0.2",
  "author": "osmhacktw",
  "description": "Taiwan Community of the OpenStreetMap 台灣開放街圖社群網站",
  "license": "0BSD",
  "type": "module",
  "keywords": [
    "OpenStreetMap",
    "OpenStreetMap Taiwan",
    "開放街圖",
    "OpenStreetMap 台灣",
    "台灣開放街圖",
    "開放街圖台灣",
    "OSMTW",
    "廣泛運用的圖資",
    "自由開放的圖資",
    "nextjs"
  ],
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "deploy": "next build --prefix-paths && gh-pages -d public",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "lint": "eslint .",
    "start": "next start",
    "prepare": "husky install",
    "ci": "rm -fr node_modules && yarn install --immutable"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@tailwindcss/postcss": "^4.2.4",
    "autoprefixer": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "next": "^15.5.15",
    "prop-types": "^15.8.1",
    "react": "19",
    "react-dom": "19",
    "react-helmet": "^6.1.0",
    "swr": "^2.4.1",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "cssnano": "7.1.7",
    "eslint": "^9",
    "eslint-config-airbnb": "19",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.30.1",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OsmHackTW/osmtw-ghpage/"
  },
  "bugs": {
    "url": "https://github.com/OsmHackTW/osmtw-ghpage/issues"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "packageManager": "yarn@4.14.1"
}
